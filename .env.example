VITE_APP_NAME=HomeTask

# Leave empty to run in local development mode backed by browser localStorage.
# Set this to your backend URL. For local API mode, run `npm run api`.
VITE_API_BASE_URL=http://localhost:8787

# Demo shortcuts should be off in production builds unless you explicitly enable them.
VITE_ENABLE_DEMO_TOOLS=false
VITE_ENABLE_LOCAL_RESET=false

# Optional production integrations. Leave empty until a provider is configured.
# Examples: vnpay, momo, zalopay, stripe
VITE_PAYMENT_PROVIDER=

# Examples: s3, cloudinary, firebase-storage, supabase-storage
VITE_UPLOAD_PROVIDER=

# Examples: websocket, pusher, firebase, supabase-realtime
VITE_REALTIME_PROVIDER=

# Backend server settings for `npm run api`.
# json keeps the old file-backed local API. sqlite uses Node's built-in SQLite module.
# postgres uses a PostgreSQL database through DATABASE_URL.
HOMETASK_DB_DRIVER=json
HOMETASK_DATA_FILE=server/data/hometask.json
HOMETASK_SQLITE_FILE=server/data/hometask.sqlite
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hometask
PGSSL=false
HOMETASK_TOKEN_SECRET=change-this-in-production
