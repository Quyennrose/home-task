{
  "name": "hometask",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "api": "node server/index.js",
    "api:postgres": "node server/run-postgres.js",
    "api:sqlite": "node --no-warnings server/run-sqlite.js",
    "build": "vite build",
    "dev": "vite",
    "dev:api": "node server/index.js",
    "dev:full": "node server/dev-full.js",
    "dev:web": "vite",
    "start": "node server/index.js",
    "test": "npm run build && npm run test:api && npm run test:frontend && npm run test:e2e",
    "test:api": "node server/smoke-test.js",
    "test:api:sqlite": "node --no-warnings server/smoke-test-sqlite.js",
    "test:frontend": "node scripts/frontend-smoke-test.js",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "lucide-react": "0.487.0",
    "motion": "12.23.24",
    "pg": "^8.16.3",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-router": "^7.14.0",
    "tw-animate-css": "1.3.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "4.1.12",
    "@vitejs/plugin-react": "4.7.0",
    "tailwindcss": "4.1.12",
    "vite": "6.4.2"
  },
  "pnpm": {
    "overrides": {
      "vite": "6.4.2"
    }
  }
}
